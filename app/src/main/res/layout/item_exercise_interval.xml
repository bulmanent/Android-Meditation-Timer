<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="6dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/intervalItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/intervalItemDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/lavender_700"
            android:textSize="12sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/intervalMoveUpButton"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="▲"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/intervalMoveDownButton"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="▼"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/intervalEditButton"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="Edit"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/intervalDeleteButton"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="Del"
        android:textSize="12sp" />
</LinearLayout>
